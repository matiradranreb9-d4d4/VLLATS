<!DOCTYPE html>
<html>
<head>

    <title>Admin Dashboard</title>

    <form method="GET">

        <input
            type="text"
            name="search"
            placeholder="Search SR-Code, Name, Instructor, Laboratory"
        >

        <button type="submit">
            Search
        </button>

    </form>

    <style>

        body{
            font-family:Arial;
            background:#f4f7fb;
            padding:30px;
        }

        h1{
            text-align:center;
            margin-bottom:30px;
        }

        .analytics{
            width:300px;
            margin:auto;
            background:white;
            padding:20px;
            border-radius:10px;
            text-align:center;
            box-shadow:0px 0px 10px rgba(0,0,0,0.1);
            margin-bottom:30px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            background:white;
        }

        table th,
        table td{
            border:1px solid #ddd;
            padding:12px;
            text-align:center;
        }

        table th{
            background:#007bff;
            color:white;
        }

    </style>

</head>
<body>

<h1>Admin Dashboard</h1>

<form method="GET">

    <input
        type="text"
        name="search"
        placeholder="Search SR-Code, Name, Instructor, Laboratory"
    >

    <button type="submit">
        Search
    </button>

</form>

<table>

    <tr>

        <th>Log ID</th>
        <th>SR-Code</th>
        <th>Student Name</th>
        <th>Program</th>
        <th>Section</th>
        <th>Instructor</th>
        <th>Laboratory</th>
        <th>Start Time</th>
        <th>End Time</th>
        <th>Timestamp Logged</th>

    </tr>

    {% for log in logs %}

    <tr>

        <td>{{ log.id }}</td>
        <td>{{ log.student.sr_code }}</td>
        <td>{{ log.student.full_name }}</td>
        <td>{{ log.student.program }}</td>
        <td>{{ log.student.section_name }}</td>
        <td>{{ log.instructor }}</td>
        <td>{{ log.laboratory }}</td>
        <td>{{ log.start_time }}</td>
        <td>{{ log.end_time }}</td>
        <td>{{ log.timestamp }}</td>

    </tr>

    {% endfor %}

</table>

</body>
</html>
